---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))].sort();
---

<Base title="Blog — Alex Kim" description="Writing about design, development, and the craft of building things.">
  <Nav />
  
  <main>
    <section class="blog-header">
      <div class="header-inner">
        <p class="header-pre">Writing</p>
        <h1 class="header-title">Thoughts on craft,<br /><em>code & design.</em></h1>
        <p class="header-sub">{allPosts.length} essays on design systems, frontend development, and building things that last.</p>
        
        <div class="tag-filter">
          <a href="/blog" class="filter-tag active">All</a>
          {allTags.map(tag => (
            <a href={`/blog/tag/${tag}`} class="filter-tag">{tag}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="posts-section">
      <div class="posts-inner">
        {allPosts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="post-item">
            <div class="post-index">{String(i + 1).padStart(2, '0')}</div>
            <div class="post-content">
              <div class="post-meta-top">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { 
                    month: 'long', 
                    day: 'numeric',
                    year: 'numeric' 
                  })}
                </time>
                {post.data.tags && (
                  <div class="post-tags">
                    {post.data.tags.map(tag => <span class="ptag">{tag}</span>)}
                  </div>
                )}
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
            </div>
            <div class="post-arrow">→</div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .blog-header {
    border-bottom: 1px solid var(--border);
    padding: 5rem 2rem 3.5rem;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .header-pre {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .header-title {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5vw, 4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .header-title em {
    font-style: italic;
    color: var(--accent);
  }

  .header-sub {
    font-size: 17px;
    color: var(--muted);
    max-width: 48ch;
    margin-bottom: 2rem;
  }

  .tag-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-tag {
    font-size: 13px;
    font-family: var(--font-mono);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    color: var(--muted);
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }

  .filter-tag:hover,
  .filter-tag.active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  /* Posts */
  .posts-section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .posts-inner {
    padding: 2rem 0;
  }

  .post-item {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-item:hover .post-title {
    color: var(--accent);
  }

  .post-item:hover .post-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .post-index {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--border);
    letter-spacing: 0.08em;
    text-align: right;
    user-select: none;
  }

  .post-content {
    min-width: 0;
  }

  .post-meta-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .post-meta-top time {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .post-tags {
    display: flex;
    gap: 0.35rem;
  }

  .ptag {
    font-size: 11px;
    font-family: var(--font-mono);
    padding: 0.15rem 0.5rem;
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
    line-height: 1.2;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    max-width: 60ch;
  }

  .post-arrow {
    font-size: 18px;
    color: var(--border);
    transition: transform 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .post-item {
      grid-template-columns: 1fr auto;
    }

    .post-index {
      display: none;
    }
  }
</style>
