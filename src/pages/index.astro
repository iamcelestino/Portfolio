---
import '../styles/global.css';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    name: "Associação Elavoko Website",
    type: "Product Design & Dev",
    year: "2025",
    description: "Associação Elavoko Website",
    tags: ["Marketing ", "Communication ", " Voluteering"],
    color: "#1a3a5c",
  },
  {
    name: "DatsEnglish",
    type: "Dev & Marketing",
    year: "2026",
    description: "DatsEnglish website for my English speaking Mentoring Business",
    tags: ["TypeScript", "Node.js", "React"],
    color: "#2d1b4e",
  },
];
---

<Base title="Celestino Trosso — Marketer-developer">
  <Nav />
  
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Available for work · Based in Angola
        </div>
        <h1 class="hero-title">
          I Code and Convert
          <em>things people</em>
          actually use.
        </h1>
        <p class="hero-sub">
          Marketer-developer hybrid with 1 years shipping products at the intersection of craft and engineering. Currently helping NGOs Conquequing the digital world in Angola.
        </p>
        <div class="hero-actions">
          <a href="/work" class="btn btn-primary">View my work</a>
          <a href="/blog" class="btn btn-ghost">Read the blog →</a>
        </div>
      </div>

      <div class="hero-figure">
        <div class="figure-card">
          <div class="figure-avatar"></div>
          <div class="figure-stats">
            <div class="stat">
              <span class="stat-num">1+</span>
              <span class="stat-label">Years of craft</span>
            </div>
            <div class="stat">
              <span class="stat-num">5+</span>
              <span class="stat-label">Projects shipped</span>
            </div>
            <div class="stat">
              <span class="stat-num">5</span>
              <span class="stat-label">Happy clients</span>
            </div>
          </div>
        </div>
        <div class="figure-tools">
          <span>Figma</span>
          <span>Astro</span>
          <span>SEO</span>
           <span>Content Creation</span>
          <span>TypeScript</span>
          <span>Laravel</span>
        </div>
      </div>
    </section>

    <!-- Selected Work -->
    <section class="section">
      <div class="section-inner">
        <div class="section-header">
          <h2 class="section-title">Selected Work</h2>
          <a href="/work" class="section-link">All projects →</a>
        </div>
        <div class="projects-grid">
          {projects.map((project, i) => (
            <article class="project-card" style={`--card-color: ${project.color}`}>
              <div class="card-header">
                <div class="card-meta">
                  <span class="card-type">{project.type}</span>
                  <span class="card-year">{project.year}</span>
                </div>
              </div>
              <div class="card-visual">
                <span class="card-num">0{i + 1}</span>
              </div>
              <div class="card-body">
                <h3 class="card-name">{project.name}</h3>
                <p class="card-desc">{project.description}</p>
                <div class="card-tags">
                  {project.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section class="section section-alt">
      <div class="section-inner">
        <div class="section-header">
          <h2 class="section-title">From the Blog</h2>
          <a href="/blog" class="section-link">All posts →</a>
        </div>
        <div class="posts-list">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-row">
              <div class="post-row-left">
                <h3 class="post-row-title">{post.data.title}</h3>
                <p class="post-row-desc">{post.data.description}</p>
              </div>
              <div class="post-row-right">
                <time class="post-row-date" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </time>
                <span class="post-row-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-inner">
        <p class="cta-pre">Got a project in mind?</p>
        <h2 class="cta-title">Let's make something<br /><em>great together.</em></h2>
        <a href="mailto:rookietoninja.dev" class="btn btn-primary btn-lg">RookieToNinja.dev</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>


