---
import '../styles/global.css';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

const timeline = [
  {
    year: "2024–Now",
    role: "Freelance Marketer & Developer",
    company: "Independent",
    desc: "Working with startups and agencies across Angola and Abroad. Projects span product design, engineering, and open source."
  },
  {
    year: "2024-",
    role: "Part-time Tech Teacher",
    company: "Instituto Politecnico Privado Lobito",
    desc: "Led design for the core recording and sharing experience. Part of the team that shipped the async video feature used by 14M people."
  },
  {
    year: "2025",
    role: "Head of Markerting and Communication",
    company: "Associação Elavoko",
    desc: "Designed the savings and investment products for the European neobank. Shipped features to 5M users across 25 markets."
  },

];

const stack = {
  "Design": ["Figma", "Illustrator", "Photoshop"],
  "Frontend": ["HTML", "CSS", "Javascript", "Astro"],
  "Backend": ["PHP", "PostgreSQL", "MySQl", "Laravel"],
  "Tools": ["Docker", "Wordpress", "Google Analytics"],
};

---

<Base title="About — Celestino Trosso" description="A little bit about who I am, what I've done, and how I work.">
  <Nav />

  <main>
    <!-- Intro -->
    <section class="about-hero">
      <div class="hero-inner">
        <div class="hero-text">
          <div>
            <p class="hero-pre">About me</p>
            <h1 class="hero-title">
              Marketer who codes.<br />
              <em>Developer who converts.</em>
            </h1>
          </div>
          <div>
            <div class="hero-body">
              <p>
                I'm Celestino Trosso, a Marketer and developer based in Angola. Studying Computer Engineering and Business Management, I've spent the last two years at the intersection of craft and engineering — making things that don't just look great but also sale.
              </p>
            </div>
            <div class="hero-link">
              <a href="" class="hero-link primary">Let's Talk →</a>
            </div>
          </div>
        </div>
        <div class="hero-image">
             <!-- <Image src="" alt="A description of my image." class="project-image" layout='constrained' width={800} height={400} /> -->
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section">
      <div class="section-inner">
        <h2 class="section-title">My Experience</h2>
        <div class="timeline">
          {timeline.map((entry, i) => (
            <div class="timeline-entry">
              <div class="entry-connector">
                <div class="connector-dot"></div>
                {i < timeline.length - 1 && <div class="connector-line"></div>}
              </div>
              <div class="entry-content">
                <h3 class="entry-role">{entry.role}</h3>
                <div class="entry-description">
                    <p class="entry-company">{entry.company}</p>
                    <p class="entry-year">{entry.year}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="stack-section">
      <div class="section-inner">
        <h2 class="section-title">Tools & Stack</h2>
        <div class="stack-grid">
          {Object.entries(stack).map(([category, tools]) => (
            <div class="stack-col">
              <h3 class="stack-category">{category}</h3>
              <ul class="stack-list" role="list">
                {tools.map(tool => (
                  <li class="stack-item">{tool}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
          <div class="cta-inner">
            <p class="cta-pre">Got a project in mind?</p>
            <h2 class="cta-title"><span>Let's make something</span><br /><em>great together.</em></h2>
            <a href="mailto:rookietoninja.dev" class="btn btn-primary btn-lg">RookieToNinja.dev</a>
          </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  /* Responsive */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-portrait {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .portrait-img { aspect-ratio: 1; }

    .stack-grid { grid-template-columns: repeat(2, 1fr); }

    .reading-inner { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 600px) {
    .values-grid { grid-template-columns: 1fr; }
    .hero-portrait { grid-template-columns: 1fr; }
    .stack-grid { grid-template-columns: 1fr 1fr; }

    .timeline-entry {
      grid-template-columns: 80px 24px 1fr;
      gap: 1rem;
    }
  }*/
</style>
