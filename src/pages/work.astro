<Base title="Work — Celestino Trosso" description="Selected projects spanning product design, frontend development, and brand identity.">
  <Nav />

  <main>
    <header class="work-header">
      <div class="container">
        <div class="header-inner">
          <p class="header-pre">Selected Work</p>
          <h1 class="header-title">Projects I'm<br /><em>proud of.</em></h1>
          <p class="header-sub">1 year of work distilled into the pieces that mattered most. A mix of Web development and Marketing</p>
        </div>
      </div>
    </header>

