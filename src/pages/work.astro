    <!-- Services -->
    <section class="services-section">
      <div class="container">
          <div class="services-inner">
        <div class="services-header">
          <h2 class="services-title">What I do</h2>
          <p class="services-sub">I work across the full product lifecycle — from shaping ideas to shipping them.</p>
        </div>
        <div class="services-grid">
          {services.map((service, i) => (
            <div class="service-card">
              <span class="service-num">0{i + 1}</span>
              <h3 class="service-name">{service.name}</h3>
              <p class="service-desc">{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
      </div>
    </section>

    <!-- CTA strip -->
    <section class="cta-section">
      <div class="container">
          <div class="cta-inner">
            <p class="cta-pre">Got a project in mind?</p>
            <h2 class="cta-title"><span>Let's make something</span><br /><em>great together.</em></h2>
            <a href="mailto:rookietoninja.dev" class="btn btn-primary btn-lg">RookieToNinja.dev</a>
          </div>
      </div>
