---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <nav class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Home">
      <span class="logo-mark">CT</span>
      <span class="logo-name">Celestino Trosso</span>
    </a>
    
    <div>
      <ul class="nav-links" role="list">
      {navLinks.map(link => (
        <li>
          <a 
            href={link.href} 
            class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="mailto:rookieToNinja.dev" class="nav-cta">
      Let's talk →
    </a>
      <div class="nav-burger-menu">
          <span class=""></span>
            <span class=""></span>
            <span class=""></span>
      </div>
    </div>
  </nav>
</header>
